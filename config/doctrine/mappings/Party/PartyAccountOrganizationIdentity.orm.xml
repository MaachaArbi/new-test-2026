<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!--
      Extension 1-1 : PK = account_id (aussi FK vers party_account).
      strategy NONE = identifiant assigné par l'application (pas de générateur).
      Colonnes non mappées : created_at, updated_at, created_by, updated_by.
    -->
    <entity name="App\Modules\Party\Domain\Entity\PartyAccountOrganizationIdentity"
            table="party_account_organization_identity">
        <id name="accountId" type="bigint" column="account_id">
            <generator strategy="NONE"/>
        </id>

        <field name="taxId" type="string" column="tax_id" length="50" nullable="true"/>
        <field name="tradeRegister" type="string" column="trade_register" length="50" nullable="true"/>
        <field name="legalFormCode" type="string" column="legal_form_code" length="30" nullable="true"/>
        <field name="isVatSubject" type="boolean" column="is_vat_subject" nullable="false"/>
        <field name="website" type="string" column="website" length="255" nullable="true"/>
    </entity>
</doctrine-mapping>
