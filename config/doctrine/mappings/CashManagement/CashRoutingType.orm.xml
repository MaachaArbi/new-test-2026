<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!--
      Référentiel seedé — lecture seule Application.
      Colonne non mappée : created_at.
      PK = code (strategy NONE).
    -->
    <entity name="App\Modules\CashManagement\Domain\Entity\CashRoutingType" table="cash_routing_type">
        <id name="code" type="string" column="code" length="30">
            <generator strategy="NONE"/>
        </id>

        <field name="label" type="string" column="label" length="80" nullable="false"/>
    </entity>
</doctrine-mapping>
