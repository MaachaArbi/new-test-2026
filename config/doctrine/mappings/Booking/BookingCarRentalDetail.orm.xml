<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!--
      Extension 1-1 : PK = booking_id (FK applicative vers booking.id).
      strategy NONE = identifiant assigné par l'application.
      Colonnes non mappées : created_at, updated_at.
      Pas d'association Doctrine vers Booking (partitionnement — FK applicative).
    -->
    <entity name="App\Modules\Booking\Domain\Entity\BookingCarRentalDetail"
            table="booking_car_rental_detail">
        <id name="bookingId" type="bigint" column="booking_id">
            <generator strategy="NONE"/>
        </id>

        <field name="vehicleCategory" type="string" column="vehicle_category" length="100" nullable="true"/>
        <field name="vehicleBrandModel" type="string" column="vehicle_brand_model" length="100" nullable="true"/>
        <field name="pickupAt" type="datetimetz_immutable" column="pickup_at" nullable="true"/>
        <field name="dropoffAt" type="datetimetz_immutable" column="dropoff_at" nullable="true"/>
        <field name="pickupLocation" type="string" column="pickup_location" length="255" nullable="true"/>
        <field name="dropoffLocation" type="string" column="dropoff_location" length="255" nullable="true"/>
    </entity>
</doctrine-mapping>
