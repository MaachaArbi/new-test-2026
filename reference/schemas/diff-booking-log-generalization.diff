-CREATE TABLE booking_log (
-    id                    BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
-    booking_id            BIGINT NOT NULL, -- FK applicative vers booking.id (voir note partitionnement)
-    event_type            VARCHAR(30) NOT NULL, -- 'created','status_change','notification_supplier','notification_client','payment','loyalty_points',...
-    description           TEXT NOT NULL,        -- ex: "Création réservation Validée FO par ENERGIE VOYAGES suite chambres disponibles..."
-    status_code_snapshot  VARCHAR(30) REFERENCES booking_status(code), -- statut du booking AU MOMENT de l'événement (confirmé sur données réelles : le log legacy porte "etat" par ligne) -- répond au besoin d'historique de statut sans table dédiée (sujets-reportes.md point 18)
-    metadata              JSONB NOT NULL DEFAULT '{}'::jsonb, -- ex: {"destinataires": [...], "montant": ...}
-    actor_account_id      BIGINT REFERENCES party_account(id), -- NULL si système/automatique
-    ip_address            INET,
-    created_at            TIMESTAMPTZ NOT NULL DEFAULT now()
-);
-
-COMMENT ON TABLE booking_log IS 'Log unifié des événements d''une réservation (remplace hotelNotifier* et tout ce qui aurait pu devenir des booléens épars, ET les colonnes FK par type de réservation du log legacy -- un seul booking_id, cf. modele-conceptuel-booking.md). Append-only, jamais modifié. status_code_snapshot permet de reconstruire l''historique de statut sans table dédiée.';
-
-CREATE INDEX idx_booking_log_booking ON booking_log(booking_id, created_at);
-CREATE INDEX idx_booking_log_event_type ON booking_log(event_type);
